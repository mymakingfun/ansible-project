# Ansible 项目常用忽略文件
# 忽略 Galaxy 下载的角色
roles/*
!roles/.gitkeep

# 忽略主机变量和组变量
host_vars/*
group_vars/*
!host_vars/.gitkeep
!group_vars/.gitkeep

# 忽略 retry 文件
*.retry

# 忽略敏感信息
*.vault
*.pem
*.key
*.crt

# 忽略临时文件
*.swp
*.swo
*.bak
*.tmp
~*

# 忽略 Python 缓存
__pycache__/
*.pyc

# 忽略自定义库和插件下的 pyc
library/__pycache__/
filter_plugins/__pycache__/
